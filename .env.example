# Supabase Dashboard → Connect → Shared Pooler → Transaction mode の URI をコピー
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
PUBLIC_ASSET_BASE_URL=https://gbbinfo-assets.pages.dev
# Cloudflare Pages の AVATAR_UPLOAD_SECRET と同じ値（npm run r2:upload-avatar 用）
AVATAR_UPLOAD_SECRET=
DEPLOY_ENV=dev
