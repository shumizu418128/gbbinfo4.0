---
interface DropdownItem {
  key: string;
  href: string;
  label: string;
  isActive?: boolean;
}

interface Props {
  items: DropdownItem[];
  align?: "left" | "right";
  /** 項目が多い場合に最大高さと縦スクロールを有効にする */
  scrollable?: boolean;
  /** scrollable 時に 4 項目分（160px）の高さに制限する */
  compactScroll?: boolean;
}

const { items, align = "right", scrollable = false, compactScroll = false } =
  Astro.props;

const panelClass = [
  `absolute top-full ${align === "right" ? "right-0" : "left-0"} z-20 mt-2 min-w-24 bg-zinc-800/80 shadow-lg backdrop-blur-md`,
  scrollable
    ? compactScroll
      ? "max-h-40 overflow-y-auto overscroll-contain"
      : "max-h-[min(24rem,calc(100dvh-5rem))] overflow-y-auto overscroll-contain"
    : "overflow-hidden",
].join(" ");
---

<details class="header-dropdown relative flex items-center">
  <summary
    class="cursor-pointer list-none text-white [&::-webkit-details-marker]:hidden"
  >
    <slot />
  </summary>
  <div class={panelClass}>
    {
      items.map((item) => (
        <a
          href={item.href}
          aria-current={item.isActive ? "page" : undefined}
          class={`block cursor-pointer p-2 text-center hover:bg-(--hover-background-color) ${
            item.isActive
              ? "font-bold text-(--gbb-color)"
              : "font-bold text-white"
          }`}
        >
          {item.label}
        </a>
      ))
    }
  </div>
</details>

<script>
  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Node)) return;

    document
      .querySelectorAll("details.header-dropdown[open]")
      .forEach((details) => {
        if (
          details instanceof HTMLDetailsElement &&
          !details.contains(target)
        ) {
          details.open = false;
        }
      });
  });

  document.querySelectorAll("details.header-dropdown").forEach((details) => {
    details.addEventListener("toggle", () => {
      if (!(details instanceof HTMLDetailsElement) || !details.open) return;
      const active = details.querySelector('[aria-current="page"]');
      active?.scrollIntoView({ block: "nearest" });
    });
  });
</script>
