---
import "../app.css";
import FaviconLink from "~/components/FaviconLink.astro";
import ThirdPartyScripts from "~/components/ThirdPartyScripts.astro";
import { createMeta } from "~/util/meta";
import { envCheck, envBannerColors } from "~/util/dev";
import {
  SITE_NAME,
  THEME_COLOR,
  toAbsoluteUrl,
  buildHreflangLinks,
  defaultOgImageUrl,
  normalizePathname,
} from "~/util/seo";
import {
  isSupportedLanguage,
  ogLocales,
  baseLocale,
} from "~/constants/languageLabels";

interface Props {
  locale: string;
  pageTitle: string;
}

const { locale, pageTitle } = Astro.props;
const env = envCheck();
const meta = createMeta(env, pageTitle);
const metaTitle = (meta[0] as { title: string }).title;
const description = (meta[1] as { content: string }).content;

const showDevBanner = Boolean(env && env !== "production");
const bannerColor =
  env !== "production" ? envBannerColors[env] : undefined;

const pathname = normalizePathname(Astro.url.pathname);
const canonicalUrl = toAbsoluteUrl(Astro.site, pathname);
const hreflangLinks = buildHreflangLinks(Astro.site, pathname);
const ogImage = defaultOgImageUrl();
const ogLocale = isSupportedLanguage(locale)
  ? ogLocales[locale]
  : ogLocales[baseLocale];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content={THEME_COLOR} />
    {
      showDevBanner && (
        <meta name="robots" content="noindex, nofollow" />
      )
    }
    <FaviconLink />
    <link
      rel="stylesheet"
      href="https://db.onlinewebfonts.com/c/efc5d27fcf85239bbfee077b689e3ac9?family=Averta+ExtraBold"
    />
    <title>{metaTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {
      hreflangLinks.map(({ hreflang, href }) => (
        <link rel="alternate" hreflang={hreflang} href={href} />
      ))
    }

    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content={ogLocale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metaTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <ThirdPartyScripts />
  </head>
  <body>
    <main>
      {
        showDevBanner && (
          <div
            role="status"
            aria-live="polite"
            class={`fixed top-0 left-0 z-50 flex h-5 w-full items-center justify-center text-xs font-bold text-white ${bannerColor}`}
          >
            {env}
          </div>
        )
      }
      <slot />
    </main>

    <script>
      const SECTION_ID_SUFFIX = "-section";
      const HEADER_OFFSET = 64;

      if ("scrollRestoration" in history) {
        history.scrollRestoration = "manual";
      }

      const resolveSectionId = (
        scrollTarget: string | null,
        hash: string,
      ): string | null => {
        if (scrollTarget) {
          const byScrollKey = document.querySelector(
            `[data-scroll-key="${CSS.escape(scrollTarget)}"]`,
          );
          if (byScrollKey instanceof HTMLElement && byScrollKey.id) {
            return byScrollKey.id;
          }
          const conventionalId = `${scrollTarget}${SECTION_ID_SUFFIX}`;
          if (document.getElementById(conventionalId)) {
            return conventionalId;
          }
        }
        if (hash.length > 1) {
          return decodeURIComponent(hash.slice(1));
        }
        return null;
      };

      const scrollToSection = (sectionId: string): boolean => {
        const element = document.getElementById(sectionId);
        if (!element) {
          return false;
        }
        const y =
          element.getBoundingClientRect().top + window.scrollY - HEADER_OFFSET;
        window.scrollTo({ top: y, behavior: "smooth" });
        return true;
      };

      const runInitialScroll = () => {
        const params = new URLSearchParams(window.location.search);
        const sectionId = resolveSectionId(
          params.get("scroll"),
          window.location.hash,
        );
        if (!sectionId) {
          return;
        }
        window.scrollTo({ top: 0, behavior: "auto" });
        requestAnimationFrame(() => {
          scrollToSection(sectionId);
        });
      };

      // 同一ページ内 #section リンクをブラウザ標準ジャンプの代わりにスムーズスクロールへ
      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) {
          return;
        }
        const anchor = target.closest('a[href^="#"]');
        if (!(anchor instanceof HTMLAnchorElement)) {
          return;
        }
        const href = anchor.getAttribute("href");
        if (!href || href === "#") {
          return;
        }
        const sectionId = decodeURIComponent(href.slice(1));
        if (!document.getElementById(sectionId)) {
          return;
        }
        event.preventDefault();
        scrollToSection(sectionId);
        window.history.pushState(
          null,
          "",
          `${window.location.pathname}${window.location.search}#${sectionId}`,
        );
      });

      // SelectMenu: 外側クリックで details を閉じる
      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Node)) {
          return;
        }
        document
          .querySelectorAll("details.select-menu[open]")
          .forEach((details) => {
            if (
              details instanceof HTMLDetailsElement &&
              !details.contains(target)
            ) {
              details.open = false;
            }
          });
      });

      // 出場者アバター画像の読み込み失敗時は要素を隠す（壊れた画像アイコンを出さない）
      document.addEventListener(
        "error",
        (event) => {
          const target = event.target;
          if (
            target instanceof HTMLImageElement &&
            target.classList.contains("js-avatar")
          ) {
            target.style.display = "none";
          }
        },
        true,
      );

      // LinkCard: unavailable/disabled 時は遷移せず Coming soon を表示
      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) {
          return;
        }
        const blockedCard = target.closest("[data-link-card-blocked]");
        if (!(blockedCard instanceof HTMLElement)) {
          return;
        }
        event.preventDefault();
        alert(blockedCard.dataset.comingSoonMessage ?? "Coming soon...");
      });

      runInitialScroll();
    </script>
  </body>
</html>
