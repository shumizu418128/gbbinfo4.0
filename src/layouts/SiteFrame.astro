---
import Layout from "./Layout.astro";
import HeaderMenu from "~/components/HeaderMenu.astro";
import HamburgerMenu from "~/components/HamburgerMenu.astro";
import { HeroImage } from "~/components/HeroImage";
import FooterMenu from "~/components/FooterMenu.astro";
import type { SupportedLanguage } from "~/constants/languageLabels";
import type { YearWithCountry } from "~/db/year";

interface Props {
  locale: SupportedLanguage;
  pageTitle: string;
  yearWithCountry?: YearWithCountry;
  years: number[];
  latestYearWithCountry: YearWithCountry;
  heroSubtitle?: string;
  heroHeading?: string;
}

const {
  locale,
  pageTitle,
  yearWithCountry,
  years,
  latestYearWithCountry,
  heroSubtitle,
  heroHeading,
} = Astro.props;

const currentPath = Astro.url.pathname;
const headerYear = yearWithCountry?.year ?? latestYearWithCountry.year;
---

<Layout locale={locale} pageTitle={pageTitle}>
  <HeaderMenu
    lang={locale}
    currentPath={currentPath}
    year={headerYear}
    years={years}
  />
  <HeroImage yearWithCountry={yearWithCountry} heroSubtitle={heroSubtitle} heroHeading={heroHeading} />
  <slot />
  <FooterMenu locale={locale} latestYearWithCountry={latestYearWithCountry} />
  <HamburgerMenu
    lang={locale}
    currentPath={currentPath}
    year={headerYear}
    years={years}
  />
</Layout>
