---
// ルートパス: 言語を自動判定し、現在の開催年のトップへリダイレクトする。
// SSG ではサーバー側で言語判定できないため、クライアントで navigator.language を見る。
const year = new Date().getFullYear();
const fallback = `/ja/${year}/top`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${fallback}`} />
    <link rel="canonical" href={fallback} />
    <script is:inline define:vars={{ year, fallback }}>
      const supported = ["ja", "en", "de"];
      const nav = (navigator.language || "ja").slice(0, 2).toLowerCase();
      const locale = supported.includes(nav) ? nav : "ja";
      window.location.replace(
        locale === "ja" ? fallback : `/${locale}/${year}/top`,
      );
    </script>
  </head>
  <body></body>
</html>
