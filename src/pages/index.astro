---
import FaviconLink from "~/components/FaviconLink.astro";
import {
  baseLocale,
  supportedLanguages,
} from "~/constants/languageLabels";
// ルートパス: 言語を自動判定し、現在の開催年のトップへリダイレクトする。
// SSG ではサーバー側で言語判定できないため、クライアントで navigator.language を見る。
const year = new Date().getFullYear();
const fallback = `/${baseLocale}/${year}/top`;
---

<!doctype html>
<html lang={baseLocale}>
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex, follow" />
    <FaviconLink />
    <meta http-equiv="refresh" content={`0; url=${fallback}`} />
    <link rel="canonical" href={new URL(fallback, Astro.site).href} />
    <script is:inline define:vars={{ year, fallback, supportedLanguages, baseLocale }}>
      const nav = (navigator.language || baseLocale).toLowerCase();
      let locale = baseLocale;
      if (nav.startsWith("zh")) {
        // 中国語は navigator.language が "zh-cn" / "zh-tw" / "zh-hk" のような
        // BCP47 表記のため、地域から簡体字/繁体字を判定する。
        locale = nav.includes("tw") || nav.includes("hk") || nav.includes("mo")
          ? "zh_Hant_TW"
          : "zh_Hans_CN";
      } else {
        const short = nav.slice(0, 2);
        if (supportedLanguages.includes(short)) {
          locale = short;
        }
      }
      window.location.replace(
        locale === baseLocale ? fallback : `/${locale}/${year}/top`,
      );
    </script>
  </head>
  <body></body>
</html>
