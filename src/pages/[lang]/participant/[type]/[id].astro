---
import SiteFrame from "~/layouts/SiteFrame.astro";
import { ParticipantMemberDetailContent } from "~/views/participantDetail/ParticipantMemberDetailContent";
import { ParticipantSingleDetailContent } from "~/views/participantDetail/ParticipantSingleDetailContent";
import { ParticipantTeamDetailContent } from "~/views/participantDetail/ParticipantTeamDetailContent";
import {
  getParticipantDetailStaticPaths,
  loadParticipantDetailPageData,
  participantDetailFrameProps,
  participantMemberDetailContentProps,
  participantSingleDetailContentProps,
  participantTeamDetailContentProps,
  type ParticipantDetailPageData,
} from "~/util/participantDetail";
import { isSupportedLanguage } from "~/constants/languageLabels";
import { isParticipantType } from "~/constants/participantType";

export const getStaticPaths = getParticipantDetailStaticPaths;

interface Props {
  pageData?: ParticipantDetailPageData;
}

const propsPageData = Astro.props.pageData;

let pageData: ParticipantDetailPageData;

if (propsPageData) {
  pageData = propsPageData;
} else {
  const lang = Astro.params.lang ?? "";
  const typeParam = Astro.params.type ?? "";
  const idParam = Astro.params.id ?? "";

  if (!isSupportedLanguage(lang) || !isParticipantType(typeParam)) {
    return Astro.redirect(`/${lang || "ja"}/404`);
  }

  const participantId = Number(idParam);
  if (!Number.isFinite(participantId)) {
    return Astro.redirect(`/${lang}/404`);
  }

  try {
    pageData = await loadParticipantDetailPageData(
      lang,
      participantId,
      typeParam,
    );
  } catch (error) {
    console.warn(
      `Participant detail not found: ${lang}/participant/${typeParam}/${participantId}`,
      error,
    );
    return Astro.redirect(`/${lang}/404`);
  }
}

const frameProps = participantDetailFrameProps(pageData);
---

<SiteFrame {...frameProps}>
  {
    pageData.type === "single" ? (
      <ParticipantSingleDetailContent
        {...participantSingleDetailContentProps(pageData)}
      />
    ) : pageData.type === "team" ? (
      <ParticipantTeamDetailContent
        {...participantTeamDetailContentProps(pageData)}
      />
    ) : (
      <ParticipantMemberDetailContent
        {...participantMemberDetailContentProps(pageData)}
      />
    )
  }
</SiteFrame>
