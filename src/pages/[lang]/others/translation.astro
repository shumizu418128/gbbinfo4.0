---
import SiteFrame from "~/layouts/SiteFrame.astro";
import { TranslationContent } from "~/views/others/TranslationContent";
import { getCommonYearData } from "~/util/staticPaths";
import { locales } from "@paraglide/runtime.js";
import * as m from "../../../../paraglide/messages.js";

export async function getStaticPaths() {
  const YEAR = new Date().getFullYear();
  const common = await getCommonYearData(YEAR);
  return locales.map((locale) => ({
    params: { lang: locale },
    props: { locale, ...common },
  }));
}

const { locale, yearWithCountry, years, latestYearWithCountry } = Astro.props;
const subtitle = m.others_translation_title();
const title = `${m.others_translation_title()} - GBBinfo`;
---

<SiteFrame
  locale={locale}
  title={title}
  subtitle={subtitle}
  yearWithCountry={yearWithCountry}
  years={years}
  latestYearWithCountry={latestYearWithCountry}
>
  <TranslationContent locale={locale} />
</SiteFrame>
