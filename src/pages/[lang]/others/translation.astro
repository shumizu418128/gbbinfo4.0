---
import SiteFrame from "~/layouts/SiteFrame.astro";
import { TranslationContent } from "~/views/others/TranslationContent";
import { getHeaderFooterData } from "~/util/staticPaths";
import { locales } from "@paraglide/runtime.js";
import * as m from "../../../../paraglide/messages.js";

export async function getStaticPaths() {
  const headerFooter = await getHeaderFooterData();
  return locales.map((locale) => ({
    params: { lang: locale },
    props: { locale, ...headerFooter },
  }));
}

const { locale, years, latestYearWithCountry } = Astro.props;
const heroSubtitle = m.others_translation_title();
const pageTitle = `${m.others_translation_title()} - GBBinfo`;
---

<SiteFrame
  locale={locale}
  pageTitle={pageTitle}
  heroSubtitle={heroSubtitle}
  heroHeading="GBBINFO"
  years={years}
  latestYearWithCountry={latestYearWithCountry}
>
  <TranslationContent locale={locale} />
</SiteFrame>
