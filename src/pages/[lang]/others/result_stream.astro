---
import SiteFrame from "~/layouts/SiteFrame.astro";
import { ResultStreamContent } from "~/views/others/ResultStreamContent";
import { getHeaderFooterData } from "~/util/staticPaths";
import { locales } from "@paraglide/runtime.js";

export async function getStaticPaths() {
  const headerFooter = await getHeaderFooterData();
  return locales.map((locale) => ({
    params: { lang: locale },
    props: { locale, ...headerFooter },
  }));
}

const { locale, years, latestYearWithCountry } = Astro.props;
const heroSubtitle = "Wildcard結果発表配信";
const pageTitle = "Wildcard結果発表配信";
---

<SiteFrame
  locale={locale}
  pageTitle={pageTitle}
  heroSubtitle={heroSubtitle}
  heroHeading="GBBinfo"
  years={years}
  latestYearWithCountry={latestYearWithCountry}
>
  <ResultStreamContent locale={locale} year={latestYearWithCountry.year} />
</SiteFrame>
