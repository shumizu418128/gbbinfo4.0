---
import SiteFrame from "~/layouts/SiteFrame.astro";
import { SevenToSmokeContent } from "~/views/others/SevenToSmokeContent";
import { getCommonYearData } from "~/util/staticPaths";
import { locales } from "@paraglide/runtime.js";

export async function getStaticPaths() {
  const YEAR = new Date().getFullYear();
  const common = await getCommonYearData(YEAR);
  return locales.map((locale) => ({
    params: { lang: locale },
    props: { locale, ...common },
  }));
}

const { locale, yearWithCountry, years, latestYearWithCountry } = Astro.props;
const heroSubtitle = "7toSmokeとは";
const pageTitle = "7toSmokeとは - GBBinfo";
---

<SiteFrame
  locale={locale}
  pageTitle={pageTitle}
  heroSubtitle={heroSubtitle}
  heroHeading="GBBINFO"
  yearWithCountry={yearWithCountry}
  years={years}
  latestYearWithCountry={latestYearWithCountry}
>
  <SevenToSmokeContent client:idle locale={locale} year={yearWithCountry.year} />
</SiteFrame>
