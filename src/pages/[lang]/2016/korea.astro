---
import SiteFrame from "~/layouts/SiteFrame.astro";
import { KoreaContent } from "~/views/2026/KoreaContent";
import { getCommonYearData } from "~/util/staticPaths";
import { findParticipants } from "~/db/participant";
import { buildAvatarImageUrlMap } from "~/util/participantAvatar";
import { locales } from "@paraglide/runtime.js";
import * as m from "@paraglide/messages.js";

export async function getStaticPaths() {
  const YEAR = 2016;
  const common = await getCommonYearData(YEAR);
  const participants = await findParticipants(YEAR, null, null, 410);
  const avatarImageUrls = await buildAvatarImageUrlMap(participants.map((participant) => participant.name));
  return locales.map((locale) => ({ params: { lang: locale }, props: { locale, participants, avatarImageUrls, ...common } }));
}

const { locale, participants, avatarImageUrls, yearWithCountry, years, latestYearWithCountry } = Astro.props;
const subtitle = m.team_korea();
const title = `GBB ${yearWithCountry.year} ${subtitle}`;
---

<SiteFrame locale={locale} title={title} subtitle={subtitle} yearWithCountry={yearWithCountry} years={years} latestYearWithCountry={latestYearWithCountry}>
  <KoreaContent participants={participants} locale={locale} avatarImageUrls={avatarImageUrls} />
</SiteFrame>
