---
import SiteFrame from "~/layouts/SiteFrame.astro";
import { JapanContent } from "~/views/2026/JapanContent";
import { getCommonYearData } from "~/util/staticPaths";
import { findParticipants } from "~/db/participant";
import { buildAvatarVideoIdMap } from "~/util/participantAvatar";
import { locales } from "@paraglide/runtime.js";
import * as m from "@paraglide/messages.js";

export async function getStaticPaths() {
  const YEAR = 2026;
  const JAPAN_ISO_CODE = 392;
  const common = await getCommonYearData(YEAR);
  const participants = await findParticipants(YEAR, null, null, JAPAN_ISO_CODE);
  const avatarVideoIds = await buildAvatarVideoIdMap(
    participants.map((p) => p.name),
  );
  return locales.map((locale) => ({
    params: { lang: locale },
    props: { locale, participants, avatarVideoIds, ...common },
  }));
}

const { locale, participants, avatarVideoIds, yearWithCountry, years, latestYearWithCountry } =
  Astro.props;
const subtitle = m.team_japan();
const title = `GBB ${yearWithCountry.year} ${subtitle}`;
---

<SiteFrame
  locale={locale}
  title={title}
  subtitle={subtitle}
  yearWithCountry={yearWithCountry}
  years={years}
  latestYearWithCountry={latestYearWithCountry}
>
  <JapanContent participants={participants} locale={locale} avatarVideoIds={avatarVideoIds} />
</SiteFrame>
