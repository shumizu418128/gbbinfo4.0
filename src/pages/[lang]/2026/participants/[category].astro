---
import SiteFrame from "~/layouts/SiteFrame.astro";
import SelectMenu from "~/components/SelectMenu.astro";
import { ParticipantsCards } from "~/views/ParticipantsCards";
import { ParticipantWorldMap } from "~/components/ParticipantWorldMap";
import { getCommonYearData } from "~/util/staticPaths";
import { findParticipants } from "~/db/participant";
import { findCategoriesByIds } from "~/db/category";
import { categorySlug } from "~/util/category";
import { locales } from "@paraglide/runtime.js";
import * as m from "@paraglide/messages.js";

export async function getStaticPaths() {
  const YEAR = 2026;
  const common = await getCommonYearData(YEAR);
  const validCategories = await findCategoriesByIds(
    common.yearWithCountry.categories ?? [],
  );
  const categoryNames = validCategories.map((c) => c.name);

  const paths = [];
  for (const category of validCategories) {
    const participants = await findParticipants(YEAR, category.id, null);
    for (const locale of locales) {
      paths.push({
        params: { lang: locale, category: categorySlug(category.name) },
        props: {
          locale,
          participants,
          selectedCategory: category,
          categoryNames,
          ...common,
        },
      });
    }
  }
  return paths;
}

const {
  locale,
  participants,
  selectedCategory,
  categoryNames,
  yearWithCountry,
  years,
  latestYearWithCountry,
} = Astro.props;

const subtitle = m.wildcard_result_and_participants({ Wildcard: "Wildcard" });
const title = `GBB ${yearWithCountry.year} ${subtitle}`;
const basePath = `/${locale}/${yearWithCountry.year}/participants`;
const categoryItems = categoryNames.map((name) => ({
  key: name,
  href: `${basePath}/${categorySlug(name)}`,
  label: name,
  isActive: name === selectedCategory.name,
}));
---

<SiteFrame
  locale={locale}
  title={title}
  subtitle={subtitle}
  yearWithCountry={yearWithCountry}
  years={years}
  latestYearWithCountry={latestYearWithCountry}
>
  <main
    class="pt-16 pb-8 text-white"
    style="background-color: var(--background-color)"
  >
    <div class="mx-auto w-full max-w-2xl px-4">
      <div class="mb-10 flex justify-center">
        <SelectMenu label={selectedCategory.name} items={categoryItems} />
      </div>

      <ParticipantsCards
        participants={participants}
        locale={locale}
        label={selectedCategory.name}
      />

      <div class="mt-10 flex justify-center">
        <SelectMenu label={selectedCategory.name} items={categoryItems} />
      </div>
    </div>

    <ParticipantWorldMap
      client:visible
      participants={participants}
      locale={locale}
    />
  </main>
</SiteFrame>
