---
import { getCommonYearData } from "~/util/staticPaths";
import { findCategoriesByIds } from "~/db/category";
import { categorySlug } from "~/util/category";
import { locales } from "@paraglide/runtime.js";

export async function getStaticPaths() {
  const YEAR = 2026;
  const common = await getCommonYearData(YEAR);
  const validCategories = await findCategoriesByIds(
    common.yearWithCountry.categories ?? [],
  );
  const firstSlug = categorySlug(validCategories[0].name);
  return locales.map((locale) => ({
    params: { lang: locale },
    props: { target: `/${locale}/${YEAR}/participants/${firstSlug}` },
  }));
}

const { target } = Astro.props;
---

<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </head>
  <body></body>
</html>
