---
import SiteFrame from "~/layouts/SiteFrame.astro";
import { KoreaContent } from "~/views/2026/KoreaContent";
import { getCommonYearData } from "~/util/staticPaths";
import { findParticipants } from "~/db/participant";
import { locales } from "@paraglide/runtime.js";
import * as m from "@paraglide/messages.js";

export async function getStaticPaths() {
  const YEAR = 2025;
  const KOREA_ISO_CODE = 410;
  const common = await getCommonYearData(YEAR);
  const participants = await findParticipants(YEAR, null, null, KOREA_ISO_CODE);
  return locales.map((locale) => ({
    params: { lang: locale },
    props: { locale, participants, ...common },
  }));
}

const { locale, participants, yearWithCountry, years, latestYearWithCountry } =
  Astro.props;
const subtitle = m.team_korea();
const title = `GBB ${yearWithCountry.year} ${subtitle}`;
---

<SiteFrame
  locale={locale}
  title={title}
  subtitle={subtitle}
  yearWithCountry={yearWithCountry}
  years={years}
  latestYearWithCountry={latestYearWithCountry}
>
  <KoreaContent participants={participants} locale={locale} />
</SiteFrame>
