{
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "type": "module",
  "scripts": {
    "sync:locales": "tsx scripts/sync/inlang-locales.ts",
    "sync:build-cache": "tsx scripts/sync/build-cache.ts",
    "sync:tavily": "tsx scripts/sync/tavily-db.ts",
    "sync:tavily:cache": "tsx scripts/sync/tavily-cache.ts",
    "build": "npm run sync:locales && npm run sync:build-cache && astro build",
    "dev": "npm run sync:locales && npm run sync:build-cache -- --skip && astro dev",
    "preview": "astro preview",
    "start": "astro preview",
    "typecheck": "astro check",
    "assets:dev": "npm run dev --prefix cloudflare",
    "assets:deploy": "npm run deploy --prefix cloudflare",
    "r2:convert-webp": "tsx scripts/r2/convert-to-webp.ts",
    "r2:upload-avatar": "tsx scripts/r2/upload-avatar.ts",
    "backup:db": "tsx scripts/backup-db-csv.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@tavily/core": "^0.7.6",
    "astro": "^7.1.0",
    "drizzle-orm": "^0.45.2",
    "leaflet": "^1.9.4",
    "lodash": "^4.18.1",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@inlang/paraglide-js": "^2.18.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/leaflet": "^1.9.21",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
  }
}
