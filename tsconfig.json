{
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "module": "ESNext",
    "resolveJsonModule": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "importsNotUsedAsValues": "error"
  },
  "include": ["./src"]
}
